{
  "env": {
    "MCP_TIMEOUT": "120000"
  },
  "includeCoAuthoredBy": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"C:\\Program Files\\nodejs\\node.exe\" \"C:\\Users\\YOURNAME\\.claude\\hooks\\caveman-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading caveman mode..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"C:\\Program Files\\nodejs\\node.exe\" \"C:\\Users\\YOURNAME\\.claude\\hooks\\caveman-mode-tracker.js\"",
            "timeout": 5,
            "statusMessage": "Tracking caveman mode..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\YOURNAME\\.claude\\hooks\\caveman-statusline.ps1\""
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "desktop-commander@claude-plugins-official": true,
    "code-modernization@claude-plugins-official": true,
    "notion@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "spinnerTipsEnabled": false,
  "effortLevel": "xhigh",
  "prefersReducedMotion": true,
  "theme": "dark",
  "permissions": {
    "allow": [
      "Bash(rtk grep *)",
      "Bash(rtk find *)",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__take_snapshot",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__click",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__wait_for",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__take_screenshot",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__fill",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__evaluate_script",
      "Bash(rtk ls *)",
      "Bash(rtk git status *)",
      "Bash(rtk git diff *)",
      "Bash(rtk git log *)",
      "Bash(rtk git show *)",
      "Bash(rtk git branch *)",
      "Bash(rtk git fetch *)",
      "Bash(rtk git stash *)",
      "Bash(rtk git remote *)"
    ]
  }
}
